<?xml version="1.0" encoding="UTF-8"?>
<ruleset name="Teedy Practice 7 PMD Ruleset"
  xmlns="http://pmd.sourceforge.net/ruleset/2.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://pmd.sourceforge.net/ruleset/2.0.0 https://pmd.github.io/pmd-6.0.0/ruleset_xml_schema.xsd">
  <description>
    Customized ruleset for Practice 7: LoC, CC, WMC-related, CBO and LCOM-related checks.
  </description>

  <!-- LoC / NCSS -->
  <rule ref="category/java/design.xml/NcssCount" />

  <!-- Cyclomatic Complexity -->
  <rule ref="category/java/design.xml/CyclomaticComplexity" />

  <!-- Coupling Between Objects -->
  <rule ref="category/java/design.xml/CouplingBetweenObjects" />

  <!-- WMC-related signal -->
  <rule ref="category/java/design.xml/TooManyMethods" />

  <!-- LCOM-related signal -->
  <rule ref="category/java/design.xml/GodClass" />
</ruleset>
